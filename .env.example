# ─── Anthropic (Claude — reasoning panel) ────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
K2_MODEL=claude-opus-4-7

# ─── K2 Think V2 (spatial camera placement) ──────────────────────
K2_THINK_API_KEY=your-k2-think-key-here
K2_THINK_BASE_URL=https://api.k2think.ai/v1
K2_THINK_MODEL=MBZUAI-IFM/K2-Think-v2

K2_THINK_BASE_URL=https://api.k2think.ai/v1
K2_THINK_MODEL=MBZUAI-IFM/K2-Think-v2

# ─── Backend ─────────────────────────────────────────────────────
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
CORS_ORIGINS=http://localhost:3000

# ─── Frontend ────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_WS_URL=ws://localhost:8000

# ─── React Bits Pro (shadcn registry) ────────────────────────────
# Used by `npx shadcn@latest add @reactbits-pro/<name>` in frontend/.
# Get the key from your reactbits.dev Pro account dashboard.
REACTBITS_LICENSE_KEY=your-reactbits-pro-key-here

